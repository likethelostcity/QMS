<script>
  const formMap = {
    'new-doc': { title: 'New Controlled Document', id: 'form-new-doc' },
    'dcr': { title: 'Document Change Request (DCR)', id: 'form-dcr' },
    'capa': { title: 'CAPA-Driven Update', id: 'form-capa' },
    'correction': { title: 'Correction or Gap', id: 'form-correction' },
    'training': { title: 'Training Material Update', id: 'form-training' },
  };

  function showForm(type) {
    document.getElementById('landingView').classList.add('hidden');
    document.querySelectorAll('.form-view').forEach(f => f.classList.remove('active'));
    document.getElementById(formMap[type].id).classList.add('active');
    document.getElementById('breadcrumb-current').textContent = formMap[type].title;
    window.scrollTo(0, 0);
  }

  function showLanding() {
    document.querySelectorAll('.form-view').forEach(f => f.classList.remove('active'));
    document.getElementById('landingView').classList.remove('hidden');
    document.getElementById('breadcrumb-current').textContent = 'QC Document Control';
    window.scrollTo(0, 0);
  }

  function selectPriority(el) {
    el.parentElement.querySelectorAll('.priority-pill').forEach(p => p.classList.remove('selected'));
    el.classList.add('selected');
  }
</script>

